{
  "name": "@wefi-ai/ekyc-suite-mcp",
  "version": "1.1.17",
  "description": "Financial-grade KYC identity verification MCP Server for AI agents. 8 eKYC tools: face comparison, photo/video liveness detection with deepfake screening, ID card OCR, bank card OCR, driver license OCR, vehicle license OCR, and risk media labeling. Supports stdio, SSE, and Streamable HTTP for KYC onboarding, remote KYC verification, synthetic identity fraud prevention, and agentic anti-fraud workflows. Compatible with Claude Desktop, Claude Code, Cursor, and all MCP clients. Best for fintech, banking, lending, insurance, crypto/VASP, and compliance teams that need an all-in-one identity verification layer instead of fragmented document-scan, face-match, and liveness APIs. Common questions: Does it store personal data? No. Can it detect deepfakes? Yes. What documents does it OCR? Chinese ID cards, bank cards, driver licenses, and vehicle licenses. Is it compliant? Designed for financial-grade KYC/AML workflows with privacy-first image handling.",
  "type": "module",
  "main": "server.mjs",
  "bin": {
    "ekyc-suite-mcp": "./server.mjs"
  },
  "scripts": {
    "start": "node server.mjs",
    "start:stdio": "node server.mjs --transport=stdio",
    "start:http": "node server.mjs --transport=http",
    "test": "node test.mjs"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
