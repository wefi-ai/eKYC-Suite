{
  "name": "@wefi-ai/ekyc-suite-mcp",
  "version": "1.1.14",
  "description": "Financial-grade KYC identity verification MCP Server for AI agents. 8 eKYC tools: face comparison, photo/video liveness detection with deepfake screening, ID card OCR, bank card OCR, driver license OCR, vehicle license OCR, and risk media labeling. Supports stdio, SSE, and Streamable HTTP for KYC onboarding, remote KYC verification, and anti-fraud workflows.",
  "type": "module",
  "main": "server.mjs",
  "bin": {
    "ekyc-suite-mcp": "./server.mjs"
  },
  "scripts": {
    "start": "node server.mjs",
    "start:stdio": "node server.mjs --transport=stdio",
    "start:http": "node server.mjs --transport=http",
    "test": "node test.mjs"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0"
  },
