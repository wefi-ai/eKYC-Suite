# eKYC Suite MCP Server — Environment Variables
# Copy this file to .env and fill in your credentials

# ============================================================
# Transport
# ============================================================
# stdio: local MCP clients, npx config, ModelScope-style local service
# http: cloud marketplace, Baidu MCP-SSE, Streamable HTTP
MCP_TRANSPORT=stdio

# HTTP mode only
HOST=0.0.0.0
PORT=3000
# Optional comma-separated host allowlist for HTTP mode, for example:
# ALLOWED_HOSTS=ekyc.example.com,localhost,127.0.0.1
ALLOWED_HOSTS=

# ============================================================
# Security/input limits
# ============================================================
# Default: 20MB
MAX_RAW_BYTES=20971520
# Default: 15s
REQUEST_TIMEOUT_MS=15000
# Default blocks plain HTTP input URLs. Set 1 only for controlled internal tests.
ALLOW_HTTP_URLS=0

# ============================================================
# Capabilities 1-7: Face comparison, liveness detection, document OCR
# ============================================================
KYC_APPID=
KYC_SECRET=

# ============================================================
# Capability 8: Media labeling (separate credential set)
# ============================================================
LABEL_APPID=
LABEL_SECRET=

# ============================================================
# How to obtain credentials / 获取方式:
#
# Option 1 (Key A only, self-service):
#   Visit https://console.cloud.tencent.com/faceid/access
#   前往腾讯云人脸核身控制台自助申请
#
# Option 2 (Key A + Key B):
#   Contact Huiyan tech support (WeChat: blue-201809)
#   联系慧眼技术支持（微信号：blue-201809）
#
# IMPORTANT / 重要提示:
#   Fill in TEST ID and TEST Secret here (free test quota).
#   请在此处填入“测试ID”和“测试Secret”。
#   Do NOT use production credentials during marketplace testing.
#   不要在广场测试阶段使用正式ID，正式ID可能产生计费。
# ============================================================
